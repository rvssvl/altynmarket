{
  "name": "@altyn-market/mobile-customer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "expo start --port 8082",
    "ios": "expo start --ios --port 8082",
    "eas:build:development": "npx --yes eas-cli@21.0.1 build --platform all --profile development",
    "eas:build:preview": "npx --yes eas-cli@21.0.1 build --platform all --profile preview",
    "eas:build:demo": "npx --yes eas-cli@21.0.1 build --platform ios --profile demo",
    "eas:submit:demo": "npx --yes eas-cli@21.0.1 submit --platform ios --latest",
    "eas:build:production": "npx --yes eas-cli@21.0.1 build --platform all --profile production",
    "eas:update:preview": "npx --yes eas-cli@21.0.1 update --channel preview",
    "eas:update:demo": "npx --yes eas-cli@21.0.1 update --channel demo",
    "eas:update:production": "npx --yes eas-cli@21.0.1 update --channel production",
    "test": "vitest run --passWithNoTests --dir src",
    "eas:release:demo": "npx --yes eas-cli@21.0.1 build --platform ios --profile demo --auto-submit --non-interactive"
  },
  "dependencies": {
    "@altyn-market/client": "workspace:*",
    "@altyn-market/domain": "workspace:*",
    "@effect/atom-react": "4.0.0-beta.90",
    "effect": "4.0.0-beta.90",
    "expo": "^56.0.12",
    "expo-asset": "^56.0.17",
    "expo-dev-client": "~56.0.23",
    "expo-modules-core": "~56.0.17",
    "expo-notifications": "~56.0.18",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.22",
    "hermes-compiler": "^250829098.0.2",
    "react": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0"
  }
}
