{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.altyn-market.kz"
      },
      "node": "22.12.0",
      "pnpm": "10.14.0"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.altyn-market.kz"
      },
      "node": "22.12.0",
      "pnpm": "10.14.0"
    },
    "e2e": {
      "distribution": "internal",
      "channel": "e2e",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.altyn-market.kz"
      },
      "node": "22.12.0",
      "pnpm": "10.14.0"
    },
    "demo": {
      "autoIncrement": true,
      "channel": "demo",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.altyn-market.kz"
      },
      "node": "22.12.0",
      "pnpm": "10.14.0"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.altyn-market.kz"
      },
      "node": "22.12.0",
      "pnpm": "10.14.0"
    }
  },
  "submit": {
    "demo": {
      "ios": {
        "ascAppId": "6791221961"
      }
    }
  }
}
