# Store the real version at /etc/altyn-market/staging.env on the VPS. Never
# commit it or place it inside a release directory.
ACME_EMAIL=ops@altyn-market.kz
API_DOMAIN=api-staging.altyn-market.kz
ADMIN_DOMAIN=admin-staging.altyn-market.kz
LANDING_DOMAIN=staging.altyn-market.kz

POSTGRES_DB=altyn_market_staging
POSTGRES_USER=altyn_market_staging
POSTGRES_PASSWORD=replace-with-a-long-random-password
# URL-encode POSTGRES_PASSWORD if it has reserved URL characters.
DATABASE_URL=postgresql://altyn_market_staging:replace-with-url-encoded-password@postgres:5432/altyn_market_staging

JWT_ACCESS_SECRET=replace-with-a-64-character-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-64-character-random-secret
AUTH_DEV_OTP=111111
BOOTSTRAP_ADMIN_PHONE=+77010000000
DELIVERY_FLAT_FEE_KZT=1500
VITE_CUSTOMER_APP_URL=
