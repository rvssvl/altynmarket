{
  email {$ACME_EMAIL}
}

(staging_access) {
  # The browser uses Authorization for both Basic auth and the backoffice's
  # Bearer session. After a successful Basic sign-in, persist a separate
  # HttpOnly same-origin cookie so Bearer requests can still reach the API.
  @requires_staging_auth not header_regexp Cookie "(^|;\\s*)altyn_staging_access={$STAGING_ACCESS_SESSION_TOKEN}(;|$)"
  basic_auth @requires_staging_auth {
    {$STAGING_ACCESS_USER} {$STAGING_ACCESS_PASSWORD_HASH}
  }
  header +Set-Cookie "altyn_staging_access={$STAGING_ACCESS_SESSION_TOKEN}; Path=/; Max-Age=43200; Secure; HttpOnly; SameSite=Strict"
}

{$PUBLIC_LANDING_DOMAIN}, {$PUBLIC_LANDING_WWW_DOMAIN} {
  encode zstd gzip
  reverse_proxy landing:4174
}

{$API_DOMAIN} {
  # Native apps cannot complete browser Basic Auth. Keep only the API public;
  # the backoffice remains protected on ADMIN_DOMAIN below.
  encode zstd gzip
  reverse_proxy api:4000
}

{$ADMIN_DOMAIN} {
  route {
    # Proxy the API through the same origin as the backoffice. Access control
    # is the application's own phone + OTP login; there is no HTTP Basic gate.
    # Effect RPC clients post to /rpc/ (trailing slash), so match both forms.
    @rpc path /rpc /rpc/
    handle @rpc {
      encode zstd gzip
      reverse_proxy api:4000
    }

    handle /realtime {
      encode zstd gzip
      reverse_proxy api:4000
    }

    handle /health {
      encode zstd gzip
      reverse_proxy api:4000
    }

    handle /uploads/* {
      encode zstd gzip
      reverse_proxy api:4000
    }

    handle {
      encode zstd gzip
      reverse_proxy backoffice:4173
    }
  }
}

{$LANDING_DOMAIN} {
  route {
    import staging_access
    encode zstd gzip
    reverse_proxy landing:4174
  }
}
