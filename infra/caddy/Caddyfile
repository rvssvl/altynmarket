{
  email {$ACME_EMAIL}
}

(staging_access) {
  # Browsers never attach HTTP Basic credentials to a cross-origin CORS
  # preflight. Let OPTIONS reach the API, which returns its CORS policy; all
  # requests that can read or mutate staging data still require Basic auth.
  @requires_staging_auth not method OPTIONS
  basic_auth @requires_staging_auth {
    {$STAGING_ACCESS_USER} {$STAGING_ACCESS_PASSWORD_HASH}
  }
}

{$PUBLIC_LANDING_DOMAIN}, {$PUBLIC_LANDING_WWW_DOMAIN} {
  encode zstd gzip
  reverse_proxy landing:4174
}

{$API_DOMAIN} {
  import staging_access
  encode zstd gzip
  reverse_proxy api:4000
}

{$ADMIN_DOMAIN} {
  import staging_access
  encode zstd gzip
  reverse_proxy backoffice:4173
}

{$LANDING_DOMAIN} {
  import staging_access
  encode zstd gzip
  reverse_proxy landing:4174
}
